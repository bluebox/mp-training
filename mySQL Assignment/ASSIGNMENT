Q9. Get the list of employee names and their respective immediate head name with  their respective department names.
  Eg: emp name | emp department name | immediate head name | immediate head department name


SELECT 
	e.name AS Employee_Name,
    dte.dept_name AS Employee_Department,
    IFNULL(ih.name, "NO HEAD") AS Immediate_Head_Name,
    dtih.dept_name AS Head_Department
FROM Employee_Table AS e
LEFT JOIN Employee_Table AS ih
ON e.immediate_head_id = ih.emp_id
LEFT JOIN Department_Table AS dte
ON dte.dept_id = e.dept_id
LEft JOIN Department_Table AS dtih
ON dtih.dept_id = ih.dept_id;



Q10. Get the list of employees whose immediate head working in location ‘madhapur’
       and whose salary is less than twice the salary of their respective immediate   heads.


SELECT 
	e.name AS Employee_Name
FROM Employee_Table AS e
LEFT JOIN Employee_Table AS ih
ON e.immediate_head_id = ih.emp_id
LEFT JOIN Employee_Info_Table AS eite
ON e.employee_info = eite.id
LEFT JOIN Employee_Office_Table AS eotih
ON eotih.emp_id = e.emp_id
LEFT JOIN Office_Table AS otih
USING(office_id)
LEFT JOIN Employee_Info_Table AS eitih
ON ih.employee_info = eitih.id
WHERE otih.place = 'Madhapur' AND 
	  (eite.salary * 2) > eitih.salary

