Q1. Get the list of employee details which should include their name,department and 
    name of the insurance type 

USE Assignment;

SELECT 
	et.name AS Employee_Name,
    dt.dept_name AS Department_name,
    it.insurance_name AS  Name_of_Insurance_Type
FROM Employee_Table AS et
JOIN Department_Table AS dt
USING (dept_id)
JOIN Insurance_Table AS it
USING (insurance_id)


Q2. Get the list of departments of employees working at particular place(e.g: Madhapur)

SE Assignment;

SELECT 
	et.name AS Employee_Name,
    ot.place AS Working_Place
FROM Employee_Table AS et
JOIN Employee_Office_Table AS eot
USING (emp_id)
JOIN Office_Table AS ot
USING (office_id)


Q3.Get the count of employees working in each location


SELECT 
    ot.place AS Working_Place,
    COUNT(ot.place) AS Total_employees
FROM Employee_Table AS et
JOIN Employee_Office_Table AS eot
USING (emp_id)
JOIN Office_Table AS ot
USING (office_id)
GROUP BY ot.place;


Q4.Get the third highest salaried employee name, insurance name and salary(Joins)


SELECT * FROM (SELECT
    DISTINCT eit.salary AS Employee_Salary,
    et.name AS Employee_name,
    it.insurance_name AS Insurance_Name
FROM Employee_Table AS et
JOIN Insurance_Table AS it
USING (insurance_id)
JOIN Employee_Info_Table AS eit
ON et.employee_info = eit.id
ORDER BY salary DESC
LIMIT 3) AS Result_Table
ORDER BY Employee_Salary 
LIMIT 1;


Q5.Get the Average salary of employees from each department for a particular location


SELECT 
	AVG(eit.salary) AS Average_salary,
    dt.dept_name AS Department_Name
FROM Employee_Table AS et
JOIN Employee_Info_Table AS eit
ON et.employee_info = eit.id
JOIN Department_Table AS dt
USING (dept_id)
GROUP BY (dept_id)


Q6. Get the sum of salaries of the employees joined after 02-01-2022 working in ‘Madhapur’


SELECT 
	SUM(Salary) AS Salary_Sum,
    Location,
    '2015-01-01' AS Above_This_DOJ
FROM (SELECT 
	eit.salary AS Salary,
	ot.place AS Location,
	eit.doj AS Date_of_Joining
FROM Employee_Table AS et
JOIN Employee_Info_Table as eit
ON et.employee_info = eit.id
JOIN Employee_Office_Table AS eot
USING (emp_id)
JOIN Office_Table AS ot
USING (office_id))
AS Result_Table
WHERE Location = 'Madhapur' AND Date_of_Joining > '2015-01-01'


Q7.Get name, department, salary of employees who joined after 20-02-2022 and  salary is greater than 20000 and has insurance either in lic or icici or both and whose work location is madhapur.


SELECT * FROM (SELECT 
	et.name AS Employee_Name,
    dt.dept_name AS Department_Name,
    eit.salary AS Salary,
    eit.doj AS DOJ,
    it.insurance_name AS Insurance_Type,
    ot.place AS Location
FROM Employee_Table AS et
JOIN Department_Table AS dt
USING (dept_id)
JOIN Employee_Info_Table AS eit
ON et.employee_info = eit.id
JOIN Insurance_Table AS it
USING (insurance_id)
JOIN Employee_Office_Table AS eot
USING (emp_id)
JOIN Office_Table AS ot
USING (office_id)) AS Result_table
WHERE Salary > 20000 AND 
	DOJ > '2015-01-01' AND 
	(Insurance_Type IN ('LIC', 'ICICI')) AND
    Location = 'Madhapur'
    
    
